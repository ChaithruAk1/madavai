# Copy to server/.env and fill in. server/.env should be gitignored. Real shell env vars override these.
APP_NAME=My App
SESSION_SECRET=change-me-to-a-long-random-string
ADMIN_KEY=change-me-too
TRIAL_DAYS=7

# Local testing only — enables /auth/dev/start (no OAuth). NEVER set in production.
ALLOW_DEV_LOGIN=1

# OAuth (create your own apps; redirect URI = {AUTH_BASE_URL}/auth/<provider>/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public URL of THIS server (no trailing slash). Needed once deployed.
# AUTH_BASE_URL=https://auth.yourdomain.com
# Web app origin(s) allowed as OAuth redirect targets (comma-separated). Loopback is always allowed.
# ALLOWED_REDIRECTS=https://app.yourdomain.com

# Stripe (billing is off until all three are set)
# STRIPE_SECRET_KEY=sk_live_or_test_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Postgres (omit to use the local JSON file)
# DATABASE_URL=postgres://...

# Admins / free-access can be listed here (comma-separated) or in admin-emails.txt / free-emails.txt
# ADMIN_EMAILS=you@gmail.com
# FREE_EMAILS=friend@gmail.com
