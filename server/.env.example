# Madav auth server — environment.
# Copy this file to "server/.env" and fill in your values. server/.env is gitignored.
# The server loads it automatically; real shell env vars override these.

# --- core ---
SESSION_SECRET=change-me-to-a-long-random-string
ADMIN_KEY=change-me-too
TRIAL_DAYS=7

# Local testing only — lets you use "Dev sign-in" without OAuth. NEVER set in production.
ALLOW_DEV_LOGIN=1

# Private beta: when set to 1, only admin or free-access (complimentary) accounts can finish sign-in.
# PRIVATE_BETA=1

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# --- Stripe (optional; billing is off until all three are set) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Postgres (optional; uses the JSON file when unset) ---
# DATABASE_URL=postgres://...

# --- admins / free access can also be set here (comma-separated) instead of the .txt files ---
# ADMIN_EMAILS=you@gmail.com
# FREE_EMAILS=friend@gmail.com,teammate@company.com
