# Public HTTPS base URL where THIS gateway is reachable (no trailing slash).
# On a free host this is the subdomain it gives you, e.g. https://madav-gw.onrender.com
PUBLIC_URL=https://your-gateway.example.com

# Port the server listens on (most hosts set PORT automatically).
PORT=8077

# Random secret used to sign internal state (any long random string).
GATEWAY_SECRET=change-me-to-a-long-random-string

# ---- GitHub OAuth app (Settings → Developer settings → OAuth Apps) ----
#   Authorization callback URL must be:  <PUBLIC_URL>/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Notion integration (Public OAuth integration) ----
#   Redirect URI must be:  <PUBLIC_URL>/oauth/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ---- Slack app (OAuth & Permissions) ----
#   Redirect URL must be:  <PUBLIC_URL>/oauth/slack/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
