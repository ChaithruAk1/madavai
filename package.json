{
  "name": "brainedge",
  "version": "0.3.0",
  "private": true,
  "description": "BrainEdge — a Claude-Desktop-style app over Anthropic, cloud, and local LLMs",
  "author": "Samskruthi Harish <chaithru@gmail.com>",
  "license": "UNLICENSED",
  "type": "module",
  "main": "electron/main.cjs",
  "bin": {
    "brainedge": "cli/brainedge.mjs"
  },
  "scripts": {
    "dev": "cross-env VITE_INCLUDE_QA=1 vite",
    "build": "vite build",
    "build:admin": "cross-env VITE_INCLUDE_QA=1 vite build",
    "preview": "vite preview",
    "wait-electron": "wait-on http://localhost:5174 && cross-env NODE_ENV=development electron .",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c cyan,yellow npm:dev npm:wait-electron",
    "electron:build": "vite build && electron-builder --win --config electron-builder.config.cjs",
    "rebuild": "electron-rebuild -f -w @homebridge/node-pty-prebuilt-multiarch",
    "qa": "node scripts/qa-external.mjs",
    "qa:ui": "node scripts/qa-external-ui.mjs",
    "qa:fast": "node scripts/qa-external.mjs --no-build",
    "qa:restore": "node scripts/qa-external.mjs restore",
    "qa:list": "node scripts/qa-external.mjs list",
    "test": "vitest",
    "test:run": "vitest run",
    "verify": "vite build && vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.150",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ink": "^5.0.1",
    "lucide-react": "^0.383.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ssh2": "^1.16.0",
    "undici": "^6.21.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^26.0.12",
    "jsdom": "^24.1.0",
    "rollup-obfuscator": "^4.1.1",
    "vite": "^5.4.1",
    "vitest": "^2.0.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.chaithrodaya.brainedge",
    "productName": "BrainEdge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/qa-runner.cjs",
      "!electron/qa-fixer.cjs",
      "!electron/admin-roster.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "cli",
        "to": "cli"
      }
    ],
    "asarUnpack": [
      "**/node_modules/@homebridge/node-pty-prebuilt-multiarch/**",
      "**/node_modules/node-pty/**"
    ],
    "npmRebuild": false,
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "onlyLoadAppFromAsar": true
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "BrainEdge-portable-${version}.exe"
    }
  }
}
