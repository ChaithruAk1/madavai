# ===== REQUIRED: your Google access (https://serper.dev) =====
SERP_API_KEY=your_serper_key_here

# ===== Pay-as-you-go, capped at $1000, then free =====
# You only pay Serper for searches you actually run. When the month's spend hits
# the cap, the engine STOPS paying and falls back to FREE search (never stops searching).
BUDGET_MODE=hard              # hard = stop paying at cap, use free after. soft = never stop paying.
MONTHLY_BUDGET_USD=1000       # max Google spend per month. Raise anytime (or setBudget()).
SERP_COST_PER_QUERY=0.001     # your Serper rate (~$0.30-1.00 / 1k) so the cap is accurate.
SERP_STRATEGY=always          # Google for every search (until the cap)

# ===== FREE fallback (used after the $1000 cap) =====
# Set SEARXNG_URL to use your own SearXNG (reliable). Leave blank = DuckDuckGo (zero infra,
# best-effort, can be rate-limited). Either way it's $0 and lower (DDG/Bing-grade) quality.
SEARXNG_URL=

# ===== Shared across replicas (so the $1000 cap is global, not per-instance) =====
REDIS_URL=redis://localhost:6379   # set in production. Blank = in-memory (single process).

# ===== Optional written answers, via the LLM you already run (OpenAI-compatible) =====
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

CACHE_TTL=900
