{
  "manifest_version": 3,
  "name": "Madav for Chrome",
  "version": "0.1.0",
  "description": "Browse with your own LLMs \u2014 a Madav browsing agent that reads pages and clicks, types, and navigates for you.",
  "key": "",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Madav"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}