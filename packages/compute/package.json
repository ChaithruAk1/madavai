{
  "name": "@madav/compute",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Madav Compute — the runCode() contract + sandboxes. Model code runs ONLY in a sandbox, never a privileged eval.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": { "types": "./dist/src/index.d.ts", "default": "./dist/src/index.js" },
    "./node": { "types": "./dist/src/node.d.ts", "default": "./dist/src/node.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsc -p tsconfig.build.json && node --test dist/test/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": { "typescript": "^5.5.0", "@types/node": "^20.14.0" }
}
