{
  "name": "@madav/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Madav shared brain — pure, provider-agnostic turn-loop helpers and orchestration (grows as legacy migrates).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/turn-helpers.test.js dist-test/test/router.test.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0"
  }
}
